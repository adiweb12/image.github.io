# Render PostgreSQL: use the "Internal Database URL" from your Render DB dashboard
# It looks like: postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/dbname
# postgres:// is also accepted — it is auto-converted to postgresql://
DATABASE_URL=postgresql://user:password@localhost:5432/movie_base
SYNC_API_KEY=change_this_to_a_long_random_secret_key
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.onrender.com
RUN_SCHEDULER=true

# Cloudinary credentials (free tier at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
